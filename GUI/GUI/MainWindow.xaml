<Window x:Class="GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModel="clr-namespace:GUI.MWM.ViewModel"
        xmlns:local="clr-namespace:GUI"
        mc:Ignorable="d"
        Title="Girandole CRV" Height="800" Width="1200"
        MinWidth="1000" MinHeight="700"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResizeWithGrip"
        Background="#1b1b1b">

    <Window.DataContext>
        <viewModel:MainViewModel/>
    </Window.DataContext>
    
    <Border Background="#252525">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="65"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- Logo Section -->
            <Border Background="#202020" Grid.Row="0" Grid.Column="0">
                <Image Source="/MVVM/View/LogoCrv.png" 
                       Stretch="Uniform" 
                       Margin="10"/>
            </Border>

            <!-- Sidebar -->
            <StackPanel Grid.Row="1" Grid.Column="0" Background="#202020">
                <RadioButton Style="{StaticResource MenuButtonTheme}"
                             IsChecked="True"
                             Command="{Binding HomeViewCommand}"
                             ToolTip="Dashboard Home">
                    <Path Data="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" 
                          Fill="White" 
                          Stretch="Uniform" 
                          Width="24" Height="24"/>
                </RadioButton>
                
                <RadioButton Style="{StaticResource MenuButtonTheme}"
                             Command="{Binding DiscoveryViewCommand}"
                             ToolTip="Impostazioni Tempi">
                    <Path Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.13,5.91,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.81,11.69,4.81,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" 
                          Fill="White" 
                          Stretch="Uniform" 
                          Width="24" Height="24"/>
                </RadioButton>
            </StackPanel>

            <!-- Header Section -->
            <Border Grid.Row="0" Grid.Column="1" Background="#202020" Padding="20,0">
                <Grid>
                    <TextBlock Text="{Binding settingsVm.ModeName, StringFormat='Stato Sistema: {0}'}"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Left"
                              Foreground="White"
                              FontSize="20"
                              FontWeight="SemiBold"/>
                    
                    <!-- Status Indicator Dot -->
                    <Button HorizontalAlignment="Right" 
                            VerticalAlignment="Center"
                            Command="{Binding ShowStatusInfoCommand}"
                            ToolTip="{Binding LastSync, StringFormat='Ultima comunicazione: {0}'}"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Ellipse x:Name="StatusDot" Width="15" Height="15" Fill="#e74c3c"/>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                        <Setter TargetName="StatusDot" Property="Fill" Value="#2ecc71"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Border Grid.Row="1" Grid.Column="1" Background="#1b1b1b" CornerRadius="15,0,0,0">
                <ContentControl Content="{Binding CurrentView}" Margin="10"/>
            </Border>

        </Grid>
    </Border>
</Window>
